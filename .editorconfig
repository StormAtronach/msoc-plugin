# EditorConfig — https://editorconfig.org
# Top-level config for the MSOC plugin repo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ sources follow the .clang-format standard (4-space, spaces).
[*.{c,cpp,cxx,cc,h,hpp,hxx,inl}]
indent_style = space
indent_size = 4

# CMake
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 4

# Data / markup files conventionally use 2-space indent.
[*.{json,yml,yaml}]
indent_size = 2

# Lua (test-mod) — match the MWSE convention.
[*.lua]
indent_style = space
indent_size = 4

# Markdown: trailing whitespace can be a hard line break; don't trim.
[*.md]
trim_trailing_whitespace = false

# Vendored dependencies keep their own upstream style — do not impose ours.
[deps/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
